#!/bin/bash

# ===== Zyphor OS Command Registry =====

source /usr/lib/zyphor/commands/show-help # zyphor help
source /usr/lib/zyphor/version/display-version # zyphor version
source /usr/lib/zyphor/err/error # <error>

source /usr/lib/zyphor/clean-everything # zyphor clean-everything
source /usr/lib/zyphor/install-package # zyphor install <package-name>
source /usr/lib/zyphor/remove-package # zyphor remove <package-name>
source /usr/lib/zyphor/upgrade-everything # zyphor upgrade-everything

# ===== Command Router =====

case "$1" in
  version) display_version ;;
  remove) remove_package "$@" ;;
  upgrade-everything) upgrade_everything ;;
  clean-everything) clean_everything ;;
  install) install_package "$@" ;;
  help|"") show_help ;;
  *) error ;;
esac